# Copiar a .env y rellenar valores reales. No commitear .env.

# Base de datos (Docker: docker compose up -d en la raíz del repo; host 5434)
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/reservas_db?schema=public"

NODE_ENV=development
PORT=4000

# Obligatorio: secreto largo y aleatorio para firmar JWT
JWT_SECRET=

JWT_EXPIRES_IN=15m

AUTH_COOKIE_NAME=auth_token
AUTH_COOKIE_SAMESITE=lax
# En producción HTTPS suele ser true; en local con HTTP usar false
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_MAX_AGE_MS=900000
AUTH_COOKIE_PATH=/

CORS_ORIGIN=http://localhost:3000

# Zona horaria IANA para horario laboral (L–V 09:00–18:00, bloques de 1 h). En tests suele usarse UTC.
BUSINESS_TIMEZONE=America/Santiago

LOG_LEVEL=debug
LOG_PRETTY=true

# Obligatorios para `npm run prisma:seed`
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=
BCRYPT_ROUNDS=12
