// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  LECTOR
}

enum ReservationStatus {
  PENDIENTE
  CONFIRMADO
  CANCELADO
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(LECTOR)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Client {
  id        String   @id @default(cuid())
  name      String
  email     String?  @unique
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reservations Reservation[]
}

model Technician {
  id        String   @id @default(cuid())
  name      String
  specialty String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reservations Reservation[]
}

/// Modelo de datos para reservas. Sprint 1 solo persiste estructura; reglas de negocio en Sprint 2.
model Reservation {
  id           String            @id @default(cuid())
  clientId     String
  technicianId String
  startAt      DateTime
  endAt        DateTime
  status       ReservationStatus @default(PENDIENTE)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  client     Client     @relation(fields: [clientId], references: [id], onDelete: Restrict)
  technician Technician @relation(fields: [technicianId], references: [id], onDelete: Restrict)

  @@index([technicianId, startAt])
}
